# Patient Management Platform Environment Configuration Template
# Copy this file to .env in the root directory and configure it for local deployment.

# ==============================================================================
# Database Credentials & Core Security
# ==============================================================================
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password_here

# Secret key used for JWT signing. Must be at least 256 bits (32 characters).
JWT_SECRET=replace_with_your_base64_encoded_jwt_secret_here

# ==============================================================================
# Docker Container Database JDBC Connections
# ==============================================================================
# Used by analytics-service
ANALYTICS_DB_URL=jdbc:postgresql://analytics-db:5432/analytics_db

# Used by patient-service
PATIENT_DB_URL=jdbc:postgresql://db:5432/patient_db

# Used by billing-service
BILLING_DB_URL=jdbc:postgresql://bill-db:5432/billing_db

# Used by doctor-service
DOCTOR_DB_URL=jdbc:postgresql://doctor-db:5432/doctor_db

# Used by appointment-service
APPOINTMENT_DB_URL=jdbc:postgresql://appointment-db:5432/appointment_db

# ==============================================================================
# Kafka KRaft Configuration
# ==============================================================================
# Generate a unique Kafka Cluster ID (16-character string)
KAFKA_CLUSTER_ID=replace_with_your_kafka_cluster_id_here
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ==============================================================================
# Redis Cache Configuration
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==============================================================================
# Frontend Environment Variables (Vite)
# ==============================================================================
# API base URL pointing to the Gateway Service port (internal route/local default is 4004)
VITE_API_BASE_URL=http://localhost:4004
